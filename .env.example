# Cairn — environment configuration
#
# Copy to `.env` and fill in. `.env` is gitignored; this file is not.
#
#   cp .env.example .env
#
# Every variable below is read somewhere in the code. If you add a new one,
# add it here too — this file is the inventory.
#
# NOTE: no credentials live here. Vertex auth uses Application Default
# Credentials, written by `gcloud auth application-default login`. This file
# says WHICH PROJECT, never WHICH SECRET — which is what makes it safe to log
# the resolved config at startup.


# ─── Vertex AI ────────────────────────────────────────────────────────────
# The master switch. Unset or false = offline mode: hash-bucket embeddings
# and keyword-routed replies. The app runs fine this way; it just can't reason.
#
# Truthy values: 1, true, yes, on (case-insensitive)
USE_VERTEX=false

# Required when USE_VERTEX is on. Everything else has a working default.
# GCP_PROJECT_ID=your-project-id

# Vertex region. Model availability varies by region — if a model 404s, this
# is the first thing to check.
GCP_REGION=us-central1


# ─── Models ───────────────────────────────────────────────────────────────
# Both are overridable because model IDs change faster than code does.
#
# ⚠ The reasoning model default is UNVERIFIED against a live project. If the
#   ID is wrong, GenerativeModel() raises, the except swallows it, and you get
#   "offline" with no explanation. Confirm the ID before assuming auth is
#   broken — it's the likeliest failure on first run.
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-005


# ─── Demo control ─────────────────────────────────────────────────────────
# Pins the active attendee. Unset = random pick at startup, cached for the
# process lifetime (the lru_cache is what makes one random choice behave like
# a login rather than re-rolling every call).
#
# Random is good for showing variety and terrible for debugging — "it broke,
# but I can't reproduce it, different attendee." Pin it when you need a
# deterministic run, or to demo a specific case on purpose:
#
#   att-1008  Trevor Nakamura   Explorer          → workshop registration is
#                                                   refused on entitlement.
#                                                   The best single demo.
#   att-1002  Rafael Ortiz      Builder           → heavily registered;
#                                                   good for schedule conflicts
#   att-1013  Lena Warsaw       Summit Executive  → a speaker; exercises the
#                                                   is_speaker path
#   att-1011  Dr. Amara Okonkwo Summit Executive  → speaker, and the honorific
#                                                   case the UI strips
#
# ACTIVE_ATTENDEE_ID=att-1008


# ─── Server ───────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API. The Vite dev server runs
# on 5173. Vite also proxies /api → :8000, so this is belt-and-braces for
# direct (non-proxied) calls.
CORS_ORIGINS=http://localhost:5173
